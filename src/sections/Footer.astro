---
// Footer-E: Social Media Grid - Focado em engajamento social e conteúdo visual
import siteConfig from '../data/siteConfig.json';
const { name, menu = [], socials = { instagram: '#', youtube: '#', tiktok: '#' } } = siteConfig as any;
const year = new Date().getFullYear();
---
<footer class="bg-white border-t border-gray-100 py-16">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-16 items-center mb-16">
      
      <!-- Lado Esquerdo: Brand e Missão -->
      <div>
        <a href="/" class="inline-flex items-center gap-3 mb-6 group">
          <div class="w-12 h-12 bg-dark rounded-2xl flex items-center justify-center text-white text-xl font-black group-hover:bg-primary transition-colors">
            {name.charAt(0).toUpperCase()}
          </div>
          <span class="text-3xl font-black text-dark tracking-tighter uppercase">{name}</span>
        </a>
        <p class="text-xl text-gray-400 font-medium leading-relaxed max-w-md">
          Analisando o cotidiano e transformando interações em cuidado especializado.
        </p>
      </div>

      <!-- Lado Direito: Social Grid (Dinâmico) -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
        {[
          { label: 'Instagram', color: 'bg-pink-500', href: socials?.instagram },
          { label: 'YouTube', color: 'bg-red-600', href: socials?.youtube },
          { label: 'TikTok', color: 'bg-dark', href: socials?.tiktok }
        ].filter(item => item.href && item.href !== '#').map(item => (
          <a href={item.href} class="p-6 rounded-3xl bg-gray-50 border border-gray-100 hover:bg-white hover:shadow-2xl hover:shadow-primary/5 transition-all group text-center">
             <div class={`w-10 h-10 ${item.color} rounded-xl mb-4 mx-auto flex items-center justify-center text-white scale-90 group-hover:scale-110 transition-transform shadow-lg`}>
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
             </div>
             <h4 class="text-xs font-black text-dark mb-1">{item.label}</h4>
          </a>
        ))}
      </div>
    </div>

    <!-- Bottom Nav -->
    <div class="pt-12 border-t border-gray-100 flex flex-col md:flex-row items-center justify-between gap-8">
      <nav class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
        {menu.map((item: any) => (
          <a href={item.href} class="text-xs font-black uppercase tracking-[0.2em] text-gray-400 hover:text-dark transition-colors">{item.label}</a>
        ))}
      </nav>
      <div class="text-[10px] font-bold text-gray-300 uppercase tracking-widest">
        © {year} {name} • Pesquisa Acadêmica de Enfermagem
      </div>
    </div>
  </div>
</footer>