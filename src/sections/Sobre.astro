---
// Sobre-B: Split com Valores — texto esquerda, valores direita, pilares abaixo
interface Props {
  title: string;
  subtitle: string;
  content: string;
  mission?: string;
  image?: string;
}
const { title, subtitle, content, mission, image } = Astro.props;
---
<!-- Hero compacto -->
<section class="relative py-16 text-white overflow-hidden" style={image ? `background: url(${image}) center/cover no-repeat` : ''}>
  <div class={`absolute inset-0 ${image ? 'bg-primary/85' : 'bg-primary'}`}></div>
  <div class="relative z-10 max-w-6xl mx-auto px-4">
    <span class="text-xs font-bold uppercase tracking-widest text-white/60 mb-3 block">Sobre Nós</span>
    <h1 class="text-4xl md:text-5xl font-black leading-tight max-w-2xl">{title}</h1>
  </div>
</section>

<!-- Split: texto + valores -->
<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <!-- Esquerda: texto -->
      <div>
        <p class="text-lg text-gray-500 leading-relaxed mb-8">{subtitle}</p>
        <p class="text-gray-600 leading-relaxed">{content}</p>
        {mission && (
          <blockquote class="mt-8 pl-5 border-l-4 border-primary italic text-gray-500 leading-relaxed">
            "{mission}"
          </blockquote>
        )}
      </div>

      <!-- Direita: valores -->
      <div class="space-y-4">
        {[
          { icon: '🎯', label: 'Foco no leitor', desc: 'Cada palavra escrita pensando em você.' },
          { icon: '🔍', label: 'Pesquisa rigorosa', desc: 'Conteúdo baseado em fontes confiáveis.' },
          { icon: '💡', label: 'Inovação constante', desc: 'Sempre evoluindo para trazer o melhor.' },
          { icon: '🤝', label: 'Transparência', desc: 'Honestidade em cada publicação.' },
        ]?.map(v => (
          <div class="flex gap-4 p-5 rounded-2xl bg-gray-50 hover:bg-primary/5 transition-colors">
            <span class="text-2xl shrink-0">{v.icon}</span>
            <div>
              <p class="font-bold text-dark">{v.label}</p>
              <p class="text-sm text-gray-500 mt-0.5">{v.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Pilares -->
<section class="py-16 bg-dark text-white">
  <div class="max-w-6xl mx-auto px-4">
    <p class="text-xs font-bold uppercase tracking-widest text-white/40 mb-10 text-center">Nossos Pilares</p>
    <div class="grid md:grid-cols-3 gap-8 text-center">
      {[
        { num: '01', label: 'Qualidade', desc: 'Padrão editorial rigoroso em cada publicação.' },
        { num: '02', label: 'Relevância', desc: 'Conteúdo que faz diferença na vida do leitor.' },
        { num: '03', label: 'Consistência', desc: 'Publicações regulares, sempre no prazo.' },
      ]?.map(p => (
        <div>
          <div class="text-5xl font-black text-primary/30 mb-3">{p.num}</div>
          <h3 class="text-lg font-black mb-2">{p.label}</h3>
          <p class="text-white/50 text-sm leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>