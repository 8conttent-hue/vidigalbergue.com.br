---
// Header-H: Double Tier (Top Bar + Main Nav)
import siteConfig from '../data/siteConfig.json';
import { getAllPosts } from '../lib/posts';

const { name, menu: baseMenu = [], contact = { email: 'contato@exemplo.com', phone: '(11) 99999-9999' } } = siteConfig;

// Buscar categorias REAIS do banco de dados (SSR)
const allPosts = await getAllPosts();
const realCategories = [...new Set(allPosts.map(p => p.category))].filter(Boolean);

// Injetar categorias reais no item "Blog" do menu
const menu = baseMenu.map((item: any) => {
  if (item.label.toLowerCase() === 'blog' || item.href === '/blog') {
    return {
      ...item,
      children: realCategories.length
        ? realCategories.map(cat => ({
            label: cat,
            href: `/categoria/${cat.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-')}`
          }))
        : undefined,
    };
  }
  return item;
});
---
<header class="w-full z-[100] shadow-sm">
  <!-- Top Bar -->
  <div class="bg-dark text-white/70 py-1.5 border-b border-white/5">
    <div class="max-w-6xl mx-auto px-4 flex justify-between items-center text-[10px] uppercase tracking-widest font-bold">
      <div class="flex gap-6 items-center">
        <span class="flex items-center gap-1.5 hover:text-white transition-colors">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          {contact.email}
        </span>
        <span class="hidden sm:flex items-center gap-1.5 hover:text-white transition-colors">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {contact.phone}
        </span>
      </div>
      <div class="flex gap-4">
        <a href="#" class="hover:text-primary transition-colors">Instagram</a>
        <a href="#" class="hover:text-primary transition-colors">YouTube</a>
      </div>
    </div>
  </div>

  <!-- Main Nav -->
  <div class="bg-white border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <div class="w-9 h-9 bg-primary p-2 flex items-center justify-center text-white">
          <svg class="w-full h-full" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        </div>
        <span class="font-black text-xl text-dark tracking-tighter uppercase">{name}</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-1 px-1 py-1 rounded-2xl bg-gray-50/50 border border-gray-100 shadow-sm">
        {menu.map((item: any) => (
        item.children?.length ? (
          <div class="relative group flex items-center">
            <button type="button" class="px-5 py-2 text-xs font-bold text-gray-400 group-hover:text-dark group-hover:bg-white rounded-xl transition-all border border-transparent group-hover:border-gray-100 group-hover:shadow-sm flex items-center gap-1 cursor-pointer">
              {item.label}
              <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="absolute top-full left-0 z-[110] pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
              <div class="w-48 bg-white border border-gray-100 shadow-2xl py-3">
                <a href={item.href} class="block px-6 py-1.5 text-[9px] font-black text-gray-300 uppercase tracking-widest mb-2 border-b border-gray-50 pb-2">Ver Blog</a>
                {item.children.map((child: any) => (
                  <a href={child.href} class="block px-6 py-2.5 text-[11px] font-bold text-gray-500 hover:text-primary hover:bg-gray-50 transition-colors uppercase tracking-wider">
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
            <a
              href={item.href}
              class="h-full px-6 flex items-center text-xs font-black uppercase tracking-widest text-gray-400 hover:text-dark hover:bg-gray-50 border-x border-transparent hover:border-gray-100 transition-all"
            >
              {item.label}
            </a>
          )
        ))}
        <a
          href="/blog"
          class="ml-6 px-6 py-2 bg-primary text-white text-xs font-black uppercase tracking-widest rounded shadow hover:shadow-lg hover:translate-y-[-1px] transition-all"
        >
          Blog
        </a>
      </nav>

      <!-- Mobile Button -->
      <button id="menu-btn-h" class="lg:hidden p-2 bg-gray-50 rounded text-dark" aria-label="Menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu-h" class="hidden lg:hidden bg-white border-t border-gray-100 p-6 space-y-3">
    {menu.map((item: any) => (
      <div>
        <a href={item.href} class="block py-3 px-4 rounded-lg bg-gray-50 text-sm font-bold text-gray-700 hover:bg-primary/5 hover:text-primary transition-all uppercase tracking-wider">{item.label}</a>
        {item.children?.length ? (
          <div class="pl-4 mt-2 space-y-2 border-l-2 border-gray-100">
            {item.children.map((child: any) => (
              <a href={child.href} class="block py-2 text-xs font-bold text-gray-500 hover:text-primary uppercase tracking-wide">{child.label}</a>
            ))}
          </div>
        ) : null}
      </div>
    ))}
  </div>
</header>

<script>
  document.getElementById('menu-btn-h')?.addEventListener('click', () => {
    document.getElementById('mobile-menu-h')?.classList.toggle('hidden');
  });
</script>