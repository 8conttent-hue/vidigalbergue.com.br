---
// About-E: Mission Cards Grid - Foco em objetivos e missão
interface Stat { value: string; label: string; }
interface Props {
  title: string;
  desc: string;
  image: string;
  btnText: string;
  btnLink: string;
  stats: Stat[];
}
const { title, desc, stats } = Astro.props;

// Categorias fixas para os cards baseado na estrutura de 3
const categories = [
  { label: 'Missão', icon: '🎯' },
  { label: 'Visão', icon: '⚡' },
  { label: 'Valores', icon: '💎' }
];
---
<section class="py-24 bg-gray-50 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Section Header -->
    <div class="max-w-3xl mx-auto text-center mb-20 relative">
      <span class="inline-block px-4 py-1.5 rounded-full bg-primary/10 text-primary text-[10px] font-black uppercase tracking-[0.2em] mb-4">
        Nosso Propósito
      </span>
      <h2 class="text-4xl md:text-6xl font-black text-dark tracking-tighter mb-8 leading-tight">
        {title}
      </h2>
      <p class="text-xl text-gray-500 leading-relaxed font-medium">
        {desc.length > 150 ? desc.substring(0, 150) + '...' : desc}
      </p>
    </div>

    <!-- Mission Cards Grid -->
    <div class="grid md:grid-cols-3 gap-8">
      {categories.map((cat, i) => (
        <div class="bg-white rounded-[2rem] p-10 shadow-sm border border-gray-100 hover:shadow-2xl hover:-translate-y-2 transition-all group overflow-hidden relative">
          <!-- Background accent -->
          <div class="absolute -top-12 -right-12 w-24 h-24 bg-primary/5 rounded-full group-hover:scale-[3] transition-transform duration-700"></div>
          
          <div class="relative z-10">
            <div class="w-16 h-16 bg-gray-50 rounded-2xl flex items-center justify-center text-3xl mb-8 group-hover:bg-primary group-hover:text-white transition-all duration-500 transform group-hover:rotate-6">
              {cat.icon}
            </div>
            <h3 class="text-2xl font-black text-dark mb-4 tracking-tight uppercase tracking-wider">{cat.label}</h3>
            <p class="text-sm text-gray-400 leading-relaxed font-medium">
              Explorando novas fronteiras no cuidado de enfermagem e na análise do comportamento através das mídias sociais.
            </p>
            
            {/* Link para o stat correspondente se houver */}
            <div class="mt-8 pt-8 border-t border-gray-50 flex items-center justify-between">
              <span class="text-3xl font-black text-dark/10 group-hover:text-primary/20 transition-colors">0{i+1}</span>
              <span class="text-[10px] font-black text-primary uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">Explorar</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>