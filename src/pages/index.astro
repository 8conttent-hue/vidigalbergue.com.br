---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../sections/Header.astro';
import Hero from '../sections/Hero.astro';
import Features from '../sections/Features.astro';
import About from '../sections/About.astro';
import Posts from '../sections/Posts.astro';
import Footer from '../sections/Footer.astro';
import homeData from '../data/home.json';
---
<BaseLayout title={homeData.meta.title} description={homeData.meta.description}>
  <Header />
  <Hero {...homeData.hero} />
  <Features {...homeData.features} />
  <About {...homeData.about} />
  <Posts {...homeData.posts} />
  <Footer />
</BaseLayout>
